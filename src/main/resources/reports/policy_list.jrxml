<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
    name="policy_list" pageWidth="595" pageHeight="842" columnWidth="515" leftMargin="40" rightMargin="40" topMargin="50" bottomMargin="50">

    <parameter name="ReportTitle" class="java.lang.String"/>

    <field name="policyNumber" class="java.lang.String"/>
    <field name="type" class="java.lang.String"/>
    <field name="sumInsured" class="java.lang.Integer"/>
    <field name="premiumAmount" class="java.lang.Double"/>
    <field name="startDate" class="java.lang.String"/>
    <field name="endDate" class="java.lang.String"/>
    <field name="status" class="java.lang.String"/>

    <title>
        <band height="50">
            <staticText>
                <reportElement x="0" y="10" width="515" height="30"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[$P{ReportTitle}]]></text>
            </staticText>
        </band>
    </title>

    <columnHeader>
        <band height="20">
            <staticText>
                <reportElement x="0" y="0" width="120" height="20"/>
                <text><![CDATA[Policy No.]]></text>
            </staticText>
            <staticText>
                <reportElement x="130" y="0" width="100" height="20"/>
                <text><![CDATA[Type]]></text>
            </staticText>
            <staticText>
                <reportElement x="240" y="0" width="80" height="20"/>
                <text><![CDATA[Sum Insured]]></text>
            </staticText>
            <staticText>
                <reportElement x="330" y="0" width="80" height="20"/>
                <text><![CDATA[Premium]]></text>
            </staticText>
            <staticText>
                <reportElement x="420" y="0" width="95" height="20"/>
                <text><![CDATA[Status]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="20">
            <textField>
                <reportElement x="0" y="0" width="120" height="20"/>
                <textFieldExpression><![CDATA[$F{policyNumber}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="130" y="0" width="100" height="20"/>
                <textFieldExpression><![CDATA[$F{type}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="240" y="0" width="80" height="20"/>
                <textFieldExpression><![CDATA[$F{sumInsured}]]></textFieldExpression>
            </textField>
            <textField pattern="#,#00.00">
                <reportElement x="330" y="0" width="80" height="20"/>
                <textFieldExpression><![CDATA[$F{premiumAmount}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="420" y="0" width="95" height="20"/>
                <textFieldExpression><![CDATA[$F{status}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

</jasperReport>
